<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0F0">

    <!-- En-tête bleu (texte changé dynamiquement selon le rôle) -->
    <TextView
        android:id="@+id/tvTitreRapports"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mes comptes-rendus"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="#1565C0"
        android:padding="16dp"/>

    <!-- Tableau -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- En-tête du tableau -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1976D2"
                android:padding="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date visite"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Praticien"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Visiteur"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Lignes du tableau (générées dynamiquement par le Fragment) -->
            <LinearLayout
                android:id="@+id/tableauRapports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
